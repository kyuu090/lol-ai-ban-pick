{
  "name": "banpick-ai",
  "version": "0.5.3",
  "description": "League of Legends ban pick insights agent",
  "author": "kyuu090",
  "main": "dist-app/main.js",
  "private": true,
  "scripts": {
    "build": "npm run compile && electron-builder --win --publish never",
    "build:locked": "npm ci && npm run build",
    "pack": "npm run compile && electron-builder --dir",
    "pack:locked": "npm ci && npm run pack",
    "compile": "node scripts/copy-static-assets.js clean && tsc -p tsconfig.build.json && node scripts/copy-static-assets.js",
    "dev": "npm run compile && node scripts/run-dev.js dist-app/main.js",
    "start": "npm run compile && electron dist-app/main.js",
    "test": "npm run compile && node scripts/run-compiled-tests.js",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.banpick.ai",
    "productName": "BanPick-ai",
    "asar": true,
    "files": [
      "dist-app/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "portable",
        "nsis"
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-setup.${ext}",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "typescript": "^6.0.3"
  }
}
