{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "*.js",
    "*.ts",
    "main/**/*.js",
    "ui/**/*.js",
    "ui/**/*.ts",
    "test/**/*.js",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "dist",
    "dist-app",
    "node_modules"
  ]
}
